{
  "manifest_version": 3,
  "name": "PromptForge",
  "version": "0.1.0",
  "description": "Improve rough prompts into clear, ready-to-use prompts.",
  "action": {
    "default_title": "PromptForge",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://promptfix.duckdns.org/*"
  ]
}
